# Database
POSTGRES_USER=sahayakan
POSTGRES_PASSWORD=sahayakan_dev_password
POSTGRES_DB=sahayakan
POSTGRES_HOST=postgres
POSTGRES_PORT=5432

# MinIO
MINIO_ROOT_USER=sahayakan
MINIO_ROOT_PASSWORD=sahayakan_dev_password
MINIO_ENDPOINT=minio:9000

# Vertex AI
GOOGLE_APPLICATION_CREDENTIALS=/secrets/service-account.json
VERTEX_PROJECT=your-gcp-project-id
VERTEX_LOCATION=us-central1

# GitHub (PAT auth - fallback when no GitHub App is configured)
GITHUB_TOKEN=your-github-token
GITHUB_REPOS=owner/repo

# GitHub App (alternative to PAT - configured via Settings UI, stored in DB)
# GITHUB_APP_ID=123456
# GITHUB_APP_PRIVATE_KEY_FILE=/secrets/github-app.pem
# GITHUB_WEBHOOK_SECRET=your-webhook-secret

# Jira
JIRA_URL=https://your-org.atlassian.net
JIRA_EMAIL=your-email@example.com
JIRA_API_TOKEN=your-jira-token
JIRA_PROJECT_KEYS=PROJ

# Knowledge Cache
KNOWLEDGE_CACHE_PATH=/data/knowledge-cache

# API Server
API_HOST=0.0.0.0
API_PORT=8000
